{
  "name": "meme-overlay",
  "version": "1.0.0",
  "description": "Overlay transparent pour recevoir des memes",
  "author": "liveMeme",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.livememe.overlay",
    "productName": "MemeOverlay",
    "files": ["main.js", "preload.js", "setup.html", "overlay.html"],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }]
    },
    "portable": {
      "artifactName": "MemeOverlay.exe"
    }
  }
}
